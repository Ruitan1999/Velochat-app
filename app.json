{
  "expo": {
    "name": "VeloChat",
    "slug": "velochat",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/velochat-splash.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/velochat-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "velochat",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VeloChat uses your location to show nearby rides.",
        "NSCameraUsageDescription": "VeloChat uses your camera for profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "velochat",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6",
          "sounds": []
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-document-picker",
      "expo-web-browser",
      [
        "onesignal-expo-plugin",
        {
          "mode": "production",
          "appGroupName": "group.velocha.onesignal"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "velochat",
    "experiments": {
      "typedRoutes": true
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#3B82F6",
      "androidMode": "default"
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "315c31b3-57bd-4a52-a9f9-9b151a05f06a"
      },
      "onesignalAppId": "da56aaa9-83c2-4ac3-8219-00a97740f710"
    }
  }
}
